# Copy to .env.local and fill in values from your hosting cPanel → MySQL Databases
# (same credentials as nautilusapi/.env on the server).
#
# This lets document Edit work locally without uploading document-update.php to PHP.

API_DB_HOST=localhost
API_DB_PORT=3306
API_DB_NAME=your_database_name
API_DB_USER=your_database_user
API_DB_PASSWORD=your_database_password

# Optional: LLM for better chat answers
# LLM_API_KEY=
