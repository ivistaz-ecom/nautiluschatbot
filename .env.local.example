# Copy to .env.local and fill in values from your hosting cPanel → MySQL Databases
# (same credentials as nautilusapi/.env on the server).
#
# This lets document Edit work locally without uploading document-update.php to PHP.
#
# IMPORTANT for category pills matching on Vercel:
# Chat categories always come from the LIVE PHP database.
# Local `data/document-overrides.json` is ignored for category pills.
# Deploy latest nautilusapi (index.php + DocumentController.php) or
# document-update.php, then re-save document categories in Admin so COM/HSEM
# (etc.) exist in the DB — then local and Vercel show the same pills.

API_DB_HOST=localhost
API_DB_PORT=3306
API_DB_NAME=your_database_name
API_DB_USER=your_database_user
API_DB_PASSWORD=your_database_password

OpenAI_API_KEY=sk-your-openai-key
OpenAI_SECRET_KEY=your_openai_secret_key_here

# PHP API (required on Vercel — browser uses /api/proxy/v1, server forwards here)
API_BACKEND_URL=https://nautilus.crafttechhub.com/api/v1

# Optional: override browser API path (default: /api/proxy/v1)
# NEXT_PUBLIC_API_URL=/api/proxy/v1

# Optional: LLM for better chat answers (Claude / OpenAI / Gemini)
# LLM_API_KEY=
# LLM_PROVIDER=claude

# OpenAI embeddings for semantic PDF search (required for "meaning" match, not just keywords)
# Get a key at https://platform.openai.com/api-keys
# Put the SAME values in Hostinger public_html/.env (PHP API), not only Vercel.
EMBEDDING_API_KEY=sk-your-openai-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512
# EMBEDDING_ENABLED=true

